import json
import os
from datetime import datetime

# 定义图书类 - 封装图书属性和行为
class Book:
    def __init__(self, book_id, title, author, category, is_available=True):
        self.book_id = book_id          # 图书编号（唯一标识）
        self.title = title              # 书名
        self.author = author            # 作者
        self.category = category        # 分类
        self.is_available = is_available # 是否可借
        self.borrower = None            # 借阅人
        self.borrow_date = None         # 借阅日期

    # 将图书对象转为字典（便于存储）
    def to_dict(self):
        return {
            "book_id": self.book_id,
            "title": self.title,
            "author": self.author,
            "category": self.category,
            "is_available": self.is_available,
            "borrower": self.borrower,
            "borrow_date": self.borrow_date.strftime("%Y-%m-%d") if self.borrow_date else None
        }

    # 从字典创建图书对象
    @classmethod
    def from_dict(cls, data):
        book = cls(
            data["book_id"],
            data["title"],
            data["author"],
            data["category"],
            data["is_available"]
        )
        book.borrower = data["borrower"]
        if data["borrow_date"]:
            book.borrow_date = datetime.strptime(data["borrow_date"], "%Y-%m-%d")
        return book

# 定义图书管理系统类 - 核心业务逻辑
class LibrarySystem:
    def __init__(self, data_file="library_data.json"):
        self.data_file = data_file      # 数据存储文件
        self.books = []                 # 图书列表
        self.load_data()                # 初始化时加载数据

    # 加载数据（从文件读取）
    def load_data(self):
        if os.path.exists(self.data_file):
            try:
                with open(self.data_file, "r", encoding="utf-8") as f:
                    data = json.load(f)
                    self.books = [Book.from_dict(book_data) for book_data in data]
                print(f"✅ Successfully loading {len(self.books)} the data of this book")
            except Exception as e:
                print(f"❌ Failed loading data: {e}")
                self.books = []
        else:
            print("📁 The data file does not exist and a new file will be created...")
            self.books = []

    # 保存数据（写入文件）
    def save_data(self):
        try:
            with open(self.data_file, "w", encoding="utf-8") as f:
                json.dump([book.to_dict() for book in self.books], f, ensure_ascii=False, indent=2)
            print("✅ Saved successfully")
        except Exception as e:
            print(f"❌ Save failed: {e}")

    # 1. 添加图书（输入功能）
    def add_book(self):
        print("\n===== add new book =====")
        book_id = input("Please enter the book number (unique): ")
        
        # 检查编号是否重复
        if any(book.book_id == book_id for book in self.books):
            print("❌ This book number already exists!")
            return
        
        title = input("Please enter the book title: ")
        author = input("Please enter the book author: ")
        category = input("Please enter a category (e.g., Novel/Technology/Education): ")
        
        # 创建图书对象并添加
        new_book = Book(book_id, title, author, category)
        self.books.append(new_book)
        self.save_data()
        print(f"✅ Book《{title}》added successfully！")

    # 2. 借阅图书（输入+业务逻辑）
    def borrow_book(self):
        print("\n===== Borrow books =====")
        book_id = input("Please enter the book ID to borrow: ")
        borrower_name = input("Please enter the borrower's name: ")
        
        # 查找图书
        target_book = None
        for book in self.books:
            if book.book_id == book_id:
                target_book = book
                break
        
        if not target_book:
            print("❌ The book was not found!")
            return
        
        if not target_book.is_available:
            print(f"❌ The book《{target_book.title}》has been {target_book.borrower} borrowed！")
            return
        
        # 执行借阅操作
        target_book.is_available = False
        target_book.borrower = borrower_name
        target_book.borrow_date = datetime.now()
        self.save_data()
        print(f"✅ Loan successful!《{target_book.title}》has been borrowed to {borrower_name}")

    # 3. 归还图书（输入+业务逻辑）
    def return_book(self):
        print("\n===== Return books =====")
        book_id = input("Please enter the book number to be returned: ")
        
        # 查找图书
        target_book = None
        for book in self.books:
            if book.book_id == book_id:
                target_book = book
                break
        
        if not target_book:
            print("❌ The book was not found!")
            return
        
        if target_book.is_available:
            print(f"❌ The book《{target_book.title}》hasen't been borrowed, no need to return!")
            return
        
        # 执行归还操作
        borrower = target_book.borrower
        target_book.is_available = True
        target_book.borrower = None
        target_book.borrow_date = None
        self.save_data()
        print(f"✅ returned successful！{borrower} has been returned《{target_book.title}》")

    # 4. 查看所有图书（输出功能）
    def view_all_books(self):
        print("\n===== book list =====")
        if not self.books:
            print("📚 No book data available.")
            return
        
        # 格式化输出
        print(f"{'Number':<10} {'Book Title':<20} {'Author':<15} {'Category':<10} {'Status':<10} {'Borrower':<10}")
        print("-" * 80)
        for book in self.books:
            status = "Available for loan" if book.is_available else "Loaned out"
            borrower = book.borrower if book.borrower else "-"
            print(f"{book.book_id:<10} {book.title:<20} {book.author:<15} {book.category:<10} {status:<10} {borrower:<10}")

    # 5. 搜索图书（输入+输出）
    def search_book(self):
        print("\n===== Book searching =====")
        keyword = input("Please enter keywords for book title/author/category: ").lower()
        results = []
        
        for book in self.books:
            if (keyword in book.title.lower() or 
                keyword in book.author.lower() or 
                keyword in book.category.lower()):
                results.append(book)
        
        # 输出搜索结果
        if not results:
            print("❌ No matching books found.")
            return
        
        print(f"\n🔍 Found {len(results)} matching books：")
        print(f"{'Number':<10} {'Book Title':<20} {'Author':<15} {'Status':<10}")
        print("-" * 60)
        for book in results:
            status = "Available for loan" if book.is_available else "Loaned out"
            print(f"{book.book_id:<10} {book.title:<20} {book.author:<15} {status:<10}")

    # 显示主菜单
    def show_menu(self):
        print("\n" + "="*40)
        print("      Book Rental Management System")
        print("="*40)
        print("1. add new book")
        print("2. Borrow books")
        print("3. Return books")
        print("4. book list")
        print("5. book searching")
        print("0. Exit the system")
        print("="*40)

# 主程序入口
def main():
    # 创建系统实例
    library = LibrarySystem()
    
    while True:
        # 显示菜单
        library.show_menu()
        
        # 获取用户输入
        choice = input("Please enter the operation number: ")
        
        # 处理用户选择
        if choice == "1":
            library.add_book()
        elif choice == "2":
            library.borrow_book()
        elif choice == "3":
            library.return_book()
        elif choice == "4":
            library.view_all_books()
        elif choice == "5":
            library.search_book()
        elif choice == "0":
            print("\n👋 Thank you for using the book rental management system. Goodbye!")
            break
        else:
            print("\n❌ Invalid input, please select again!")
        
        # 按回车继续
        input("\nPress the Enter key to return to the main menu...")

# 程序启动
if __name__ == "__main__":
    main()
